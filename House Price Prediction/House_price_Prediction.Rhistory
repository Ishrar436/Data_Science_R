regression_metrics(train_data$SalePrice_log, linear_model)),
cbind(Model = "Linear Regression - Tuned", Dataset = "Train",
regression_metrics(train_data$SalePrice_log,final_tuned_lm )),
cbind(Model = "Random Forest - Normal", Dataset = "Train",
regression_metrics(train_data$SalePrice_log, rf_model)),
